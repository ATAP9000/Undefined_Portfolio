{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "undefined-portfolio",
  "compatibility_date": "2026-07-02",
  "main": "_worker.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "GITHUB_TOKEN": "",
    "RESEND_API_KEY": "",
    "CONTACT_EMAIL": ""
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
