# SEO / Meta tags (injected into index.html at build time)
VITE_SITE_TITLE=Angelo Tarazona — FullStack Developer
VITE_SITE_DESCRIPTION=Full-stack developer specializing in .NET, PHP/Laravel, React, and Ruby on Rails.
VITE_AUTHOR=Angelo Tarazona
VITE_KEYWORDS=fullstack, .NET, PHP, Laravel, React, Ruby on Rails, portfolio
VITE_SITE_URL=https://your-site.pages.dev
VITE_OG_IMAGE=https://your-site.pages.dev/favicon.svg

# GitHub GraphQL API (for pinned repos in Projects section)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Resend API (for contact form emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=your@email.com

# API endpoints (set in Cloudflare Pages, not needed locally)
# VITE_PROJECTS_API=/api/projects
# VITE_API_URL=/api/send
